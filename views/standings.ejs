<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="./styles.css">
    <title>Standings</title>
</head>

<body>
    <nav class="nav">
        <a href="/" class="<%= locals.page === 'home' ? 'active' : '' %>">🗓️ Today</a>
        <a href="/live" class="<%= locals.page === 'live' ? 'active' : '' %>">🔴 Live</a>
        <a href="/standings" class="<%= locals.page === 'standings' ? 'active' : '' %>">📈 Standings</a>
    </nav>
    <div class="container container-wide">
        <a href="/" class="back-btn">◁ Back</a>

        <div class="league-header">
            <img src="<%= leagueLogo %>" alt="<%= leagueName %>">
            <h1>
                <%= leagueName %> <span>
                        <%= season %>
                    </span>
            </h1>
        </div>

        <table class="standings-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Team</th>
                    <th>P</th>
                    <th>W</th>
                    <th>D</th>
                    <th>L</th>
                    <th>GF</th>
                    <th>GA</th>
                    <th>GD</th>
                    <th>Pts</th>
                    <th>Form</th>
                </tr>
            </thead>
            <tbody>
                <% teams.forEach(team=> { %>
                    <tr>
                        <td>
                            <%= team.rank %>
                        </td>
                        <td class="team-name">
                            <img src="<%= team.team.logo %>" alt="<%= team.team.name %>">
                            <%= team.team.name %>
                        </td>
                        <td>
                            <%= team.all.played %>
                        </td>
                        <td>
                            <%= team.all.win %>
                        </td>
                        <td>
                            <%= team.all.draw %>
                        </td>
                        <td>
                            <%= team.all.lose %>
                        </td>
                        <td>
                            <%= team.all.goals.for %>
                        </td>
                        <td>
                            <%= team.all.goals.against %>
                        </td>
                        <td>
                            <%= team.goalsDiff %>
                        </td>
                        <td class="points">
                            <%= team.points %>
                        </td>
                        <td class="form">
                            <% team.form.split("").forEach(result=> { %>
                                <span class="form-<%= result %>">
                                    <%= result %>
                                </span>
                                <% }) %>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
    </div>
</body>

</html>